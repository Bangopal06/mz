{
  "name": "whatsapp-broadcast-crm",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/gateway"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:gateway": "npm run dev --workspace=apps/gateway",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace=apps/web",
    "build:gateway": "npm run build --workspace=apps/gateway",
    "test": "npm run test --workspaces",
    "test:web": "npm run test --workspace=apps/web",
    "test:gateway": "npm run test --workspace=apps/gateway",
    "lint": "npm run lint --workspaces"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
